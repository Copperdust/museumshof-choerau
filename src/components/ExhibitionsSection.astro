---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const exhibitionFiles = import.meta.glob('../content/exhibitions/*.md', { eager: true });
const exhibitions = Object.values(exhibitionFiles)
  .map((file: any) => ({
    title: file.frontmatter.title,
    image: base + file.frontmatter.image.replace(/\.(jpg|jpeg|png)$/i, '.webp'),
    order: file.frontmatter.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order);
---

<section id="ausstellungen" class="site-section">
  <div class="container">
    <h2>Unsere Ausstellungsbereiche</h2>
    <div class="grid-wrapper">
    <div class="grid">
      {exhibitions.map((ex) => (
        <div class="card-wrapper">
          <div class="card">
            <div class="card-image">
              <img src={ex.image} alt={ex.title} loading="lazy" />
            </div>
            <h3>{ex.title}</h3>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use 'sass:math';
  @use '../styles/fluid' as *;

  $container-max: 1500;
  $gap-px: 24;
  $gap-pct: percentage(math.div($gap-px, $container-max));

  .container {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .grid-wrapper {
    width: 100%;
    margin-right: -#{$gap-pct};
    margin-right: -#{$gap-pct};
  }

  .grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }

  .card-wrapper {
    @include fluid-prop(padding, 4px, 5px, 6px, 8px);
    flex: 0 0 33.3333%;
    max-width: 320px;
  }

  @media (min-width: 1024px) {
    .card-wrapper {
      flex: 0 0 16.6666%;
      max-width: none;
    }
  }

  .card {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .card-image {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  h3 {
    font-size: clamp(0.7rem, 0.45rem + 1.3vw, 1.1rem);
    color: var(--card-heading);
    text-align: center;
    padding: clamp(0.35rem, 0.2rem + 0.7vw, 0.8rem);

    @media (min-width: 420px) {
      font-size: clamp(0.85rem, 0.7rem + 0.9vw, 1.1rem);
      padding: clamp(0.45rem, 0.3rem + 0.6vw, 0.8rem);
    }

    @media (min-width: 1024px) {
      font-size: clamp(0.85rem, 0.55rem + 0.55vw, 1rem);
      padding: clamp(0.4rem, 0.2rem + 0.4vw, 0.7rem);
    }
  }
</style>
