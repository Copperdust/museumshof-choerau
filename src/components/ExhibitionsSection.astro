---
const exhibitionFiles = import.meta.glob('../content/exhibitions/*.md', { eager: true });
const exhibitions = Object.values(exhibitionFiles)
  .map((file: any) => ({
    title: file.frontmatter.title,
    image: file.frontmatter.image,
    order: file.frontmatter.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order);
---

<section id="ausstellungen" class="site-section">
  <div class="container">
    <h2>Unsere Ausstellungsbereiche</h2>
    <div class="grid">
      {exhibitions.map((ex) => (
        <div class="card">
          <div class="card-image">
            <img src={ex.image} alt={ex.title} loading="lazy" />
          </div>
          <h3>{ex.title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .card-image {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  h3 {
    font-size: var(--font-h3);
    color: var(--card-heading);
    text-align: center;
    padding: 1rem;
  }
</style>
