---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const exhibitionFiles = import.meta.glob('../content/exhibitions/*.md', { eager: true });
const exhibitions = Object.values(exhibitionFiles)
  .map((file: any) => ({
    title: file.frontmatter.title,
    image: base + file.frontmatter.image.replace(/\.(jpg|jpeg|png)$/i, '.webp'),
    order: file.frontmatter.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order);
---

<section id="ausstellungen" class="site-section">
  <div class="container">
    <h2>Unsere Ausstellungsbereiche</h2>
    <div class="grid-wrapper">
    <div class="grid">
      {exhibitions.map((ex) => (
        <div class="card-wrapper">
          <div class="card">
            <div class="card-image">
              <img src={ex.image} alt={ex.title} loading="lazy" />
            </div>
            <h3>{ex.title}</h3>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use 'sass:math';
  @use '../styles/fluid' as *;

  $container-max: 950;
  $gap-px: 24;
  $gap-pct: percentage(math.div($gap-px, $container-max));

  .container {
    --container-max: #{$container-max}px;
    max-width: var(--container-max);
    margin: 0 auto;
    padding-inline: 1.5rem;
  }

  @media (min-width: 1680px) {
    .container {
      --container-max: clamp(950px, 281.82px + 39.773vw, 1300px);
    }
  }

  .grid-wrapper {
    width: 100%;
    margin-right: -#{$gap-pct};
    margin-right: -#{$gap-pct};
  }

  .grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }

  .card-wrapper {
    @include fluid-prop(padding, 6px, 6px, 9px, 12px);
    flex: 0 0 275px;
  }

  @media (min-width: 1680px) {
    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }

    .card-wrapper {
      flex: none;
    }
  }

  .card {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .card-image {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  h3 {
    font-size: 1.1rem;
    color: var(--card-heading);
    text-align: center;
    @include fluid-prop(padding, 0.6rem, 0.8rem, 1rem, 1rem);

    @media (min-width: 1680px) {
      font-size: clamp(1.1rem, 0.909rem + 0.1818vw, 1.2rem);
    }
  }
</style>
