---
const exhibitionFiles = import.meta.glob('../content/exhibitions/*.md', { eager: true });
const exhibitions = Object.values(exhibitionFiles)
  .map((file: any) => ({
    title: file.frontmatter.title,
    image: file.frontmatter.image,
    order: file.frontmatter.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order);
---

<section id="ausstellungen" class="site-section">
  <div class="container">
    <h2>Unsere Ausstellungsbereiche</h2>
    <div class="grid-wrapper">
    <div class="grid">
      {exhibitions.map((ex) => (
        <div class="card-wrapper">
          <div class="card">
            <div class="card-image">
              <img src={ex.image} alt={ex.title} loading="lazy" />
            </div>
            <h3>{ex.title}</h3>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use 'sass:math';
  @use '../styles/fluid' as *;

  $container-max: 1200;
  $gap-px: 24;
  $gap-pct: percentage(math.div($gap-px, $container-max));

  .container {
    --container-max: #{$container-max}px;
    max-width: var(--container-max);
    margin: 0 auto;
    padding-inline: 1.5rem;
  }

  .grid-wrapper {
    width: 100%;
    margin-right: -#{$gap-pct};
    margin-right: -#{$gap-pct};
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    justify-content: center;
  }

  .card-wrapper {
    @include fluid-prop(padding, 6px, 6px, 9px, 12px);
    max-width: calc(var(--container-max) / 3);
    margin: 0 auto;
  }

  .card {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .card-image {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  h3 {
    font-size: var(--font-h3);
    color: var(--card-heading);
    text-align: center;
    @include fluid-prop(padding, 0.6rem, 0.8rem, 1rem, 1rem);
  }
</style>
