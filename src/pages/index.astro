---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.vue';
import HeroSection from '../components/HeroSection.vue';
import ExhibitionsSection from '../components/ExhibitionsSection.astro';
import GallerySection from '../components/GallerySection.vue';
import MuseumDescriptionSection1 from '../components/MuseumDescriptionSection1.astro';
import MuseumDescriptionSection2 from '../components/MuseumDescriptionSection2.astro';
import EventsSection from '../components/EventsSection.vue';
import HoursSection from '../components/HoursSection.astro';
import ContactSection from '../components/ContactSection.astro';
import MapSection from '../components/MapSection.astro';
import DatenschutzSection from '../components/DatenschutzSection.astro';
import AktuellesSection from '../components/AktuellesSection.astro';
import ImageBanner from '../components/ImageBanner.vue';
import FooterSection from '../components/FooterSection.vue';

// Rewrite image paths to use build-generated WebP
const toWebp = (path: string) => path.replace(/\.(jpg|jpeg|png)$/i, '.webp');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Site config
const siteConfig = await import('../content/site.md');
const { heroTitle, heroSubtitle, youtubeVideo } = siteConfig.frontmatter;
const logo = base + toWebp(siteConfig.frontmatter.logo);

// Load events from markdown files in content/events/
const eventFiles = import.meta.glob('../content/events/*.md', { eager: true });
const events = Object.values(eventFiles)
  .filter((file: any) => file.frontmatter.title !== 'Beispiel')
  .map((file: any) => ({
    title: file.frontmatter.title,
    date: file.frontmatter.date,
    description: file.frontmatter.description || '',
  }));

// Collect all gallery + banner images with dimensions for hero
// Astro's import.meta.glob with eager gives us image metadata at build time
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/public/images/gallery/*.webp',
  { eager: true }
);

const MIN_WIDTH = 800;
const MIN_HEIGHT = 600;

const heroImageCandidates = Object.entries(imageModules)
  .map(([path, mod]) => ({
    src: base + path.replace('/public', ''),
    width: mod.default.width,
    height: mod.default.height,
  }))
  .filter((img) => img.width >= MIN_WIDTH && img.height >= MIN_HEIGHT);
---

<Layout>
  <NavBar client:load logo={logo} />
  <HeroSection client:only="vue" images={heroImageCandidates} title={heroTitle} subtitle={heroSubtitle} />
  <ExhibitionsSection />
  <GallerySection client:visible youtubeVideo={youtubeVideo} base={base} />
  <AktuellesSection />
  <EventsSection client:visible events={events} />
  <ImageBanner client:only="vue" images={heroImageCandidates} height="25vh" slant={30} imageSlant={-20} padded />
  <MuseumDescriptionSection1 />
  <ImageBanner client:only="vue" images={heroImageCandidates} height="25vh" slant={-30} imageSlant={20} padded />
  <MuseumDescriptionSection2 />
  <ImageBanner client:only="vue" images={heroImageCandidates} height="25vh" slant={30} imageSlant={-20} padded />
  <HoursSection />
  <ContactSection />
  <MapSection />
  <DatenschutzSection />
  <FooterSection />
</Layout>
