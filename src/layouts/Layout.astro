---
import '../styles/global.scss';

interface Props {
  title?: string;
}

const { title = 'Museumshof Chorau - Das Leben in den Jahren 1930-1989' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Museumshof Chorau - Erleben Sie das Leben in den Jahren 1930 bis 1989. Ein umgebauter Dreiseitenhof mit Wohnungen, Spielzeugmuseum, Radio- und Fernsehmuseum." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Open+Sans:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
